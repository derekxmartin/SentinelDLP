# ---- Required in production ----
DLP_JWT_SECRET=your-strong-random-secret-here
DLP_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/akeso_dlp
DLP_CORS_ORIGINS=["https://your-domain.com"]

# ---- Optional ----
DLP_DEBUG=false
DLP_GRPC_PORT=50051
DLP_LOG_LEVEL=info
DLP_LOG_FORMAT=json

# ---- SIEM Integration ----
DLP_SIEM_ENABLED=false
DLP_SIEM_ENDPOINT=http://localhost:9200/api/v1/ingest
DLP_SIEM_API_KEY=

# ---- Network Monitor ----
DLP_NETWORK_HTTP_PROXY_ENABLED=false
DLP_NETWORK_SMTP_RELAY_ENABLED=false
